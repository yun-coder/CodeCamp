{
  "name": "zz-print",
  "private": true,
  "version": "0.0.0",
  "main": "main.js",
  "scripts": {
    "dev": "vite",
    "build": "vite build",
    "preview": "vite preview",
    "start": "electron .",
    "electron:dev": "vite & timeout /t 3 /nobreak && electron .",
    "pack": "electron-builder --dir",
    "dist": "electron-builder --win --x64"
  },
  "volta": {
    "node": "22.22.1",
    "npm": "10.9.4"
  },
  "build": {
    "appId": "com.zzprint.app",
    "productName": "中造打印",
    "directories": {
      "output": "dist"
    },
    "files": [
      "dist/**/*",
      "main.js",
      "preload.js",
      "package.json",
      "static/**/*"
    ],
    "win": {
      "target": [
        {
          "target": "nsis",
          "arch": [
            "x64"
          ]
        }
      ],
      "icon": "build/logo.ico"
    },
    "nsis": {
      "oneClick": false,
      "allowElevation": true,
      "allowToChangeInstallationDirectory": true,
      "installerIcon": "build/logo.ico",
      "uninstallerIcon": "build/logo.ico",
      "installerHeaderIcon": "build/logo.ico",
      "createDesktopShortcut": true,
      "createStartMenuShortcut": true,
      "shortcutName": "中造打印"
    }
  },
  "dependencies": {
    "ant-design-vue": "^4.2.6",
    "dayjs": "^1.11.19",
    "jsbarcode": "^3.11.6",
    "qrcode": "^1.5.4",
    "stompjs": "^2.3.3",
    "vue": "^3.5.24",
    "ws": "^8.18.1"
  },
  "devDependencies": {
    "@vitejs/plugin-vue": "^6.0.1",
    "electron": "^35.0.0",
    "electron-builder": "^26.0.12",
    "electron-packager": "^17.1.2",
    "vite": "^7.2.4"
  }
}
