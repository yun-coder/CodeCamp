# pixelforge — example environment variables
# 复制为 .env 并填入实际密钥
#
# MiniMax API（必填）：https://www.minimaxi.com/
# PaddleOCR Token（推荐）：https://paddleocr.aistudio.com/token

# ── MiniMax VL + 图像编辑（必须）─────────────────────────────────────
# MiniMax API 密钥，在 minimaxi.com 开放平台获取
MINIMAX_API_KEY=
# MiniMax API 地址（默认无需修改）
MINIMAX_BASE_URL=https://api.minimax.chat/v1

# 启用视觉定位（Grounding / 规划替换区域）
MINIMAX_VISION_PLAN_ENABLED=1

# 启用图像编辑（产品替换）
MINIMAX_IMAGE_EDIT_ENABLED=1

# MiniMax 视觉理解模型（默认 MiniMax-VL-01）
MINIMAX_VISION_MODEL=MiniMax-VL-01
# MiniMax 图像生成模型（默认 image-01）
MINIMAX_IMAGE_MODEL=image-01
MINIMAX_IMAGE_QUALITY=medium

# ── PaddleOCR Cloud（推荐）──────────────────────────────────────────
# 在 https://paddleocr.aistudio.com/token 免费获取
PADDLEOCR_ACCESS_TOKEN=74d25967983681352634a5e2c3777f4554850d3d

# ── Segment Anything（本地分割，可选）────────────────────────────────
# 权重：curl -L -o checkpoints/sam_vit_b_01ec64.pth \
#   https://dl.fbaipublicfiles.com/segment_anything/sam_vit_b_01ec64.pth
SAM_CHECKPOINT=./checkpoints/sam_vit_b_01ec64.pth
SAM_DEVICE=cpu

# ── SAM2（可选）──────────────────────────────────────────────────────
SAM2_CHECKPOINT=./checkpoints/sam2.1_hiera_small.pt
SAM2_DEVICE=cpu

# ── Human parser SCHP（可选）─────────────────────────────────────────
# 权重：python -c "import gdown; gdown.download('https://drive.google.com/uc?id=1k4dllHpu0bdx38J7H28rVVLpU-kOHmnH', 'checkpoints/exp-schp-201908261155-lip.pth', quiet=False)"
SCHP_CHECKPOINT=./checkpoints/exp-schp-201908261155-lip.pth
SCHP_DEVICE=cpu

# ── 图像编辑 Provider ───────────────────────────────────────────────
# minimax_images = MiniMax 自有模型（默认）
# custom_http   = 接入其他 HTTP 图片编辑服务
# none          = 禁用
IMAGE_EDIT_PROVIDER=minimax_images

# ── 存储 ────────────────────────────────────────────────────────────
PIXELFORGE_OUTPUT_DIR=./pixelforge_runs
PIXELFORGE_PORT=8700
PIXELFORGE_LOG_LEVEL=INFO
