# Optional. Defaults to ./runs
ILA_DATA_DIR=./runs

# Future provider hooks. The MVP runs without these.
OPENAI_API_KEY=
OPENAI_BASE_URL=https://api.openai.com/v1
OPENAI_MODEL=gpt-4.1-mini
OPENAI_API_MODE=responses
OPENAI_REQUEST_TIMEOUT=120
QWEN_VL_ENDPOINT=
SAM2_MODEL_PATH=
FLUX_KONTEXT_ENDPOINT=

# OCR uses PaddleOCR official cloud API by default. Use "none" to disable OCR.
ILA_OCR_PROVIDER=paddleocr_cloud
PADDLEOCR_ACCESS_TOKEN=
PADDLEOCR_BASE_URL=https://paddleocr.aistudio-app.com
PADDLEOCR_MODEL=PaddleOCR-VL-1.6
PADDLEOCR_REQUEST_TIMEOUT=300
PADDLEOCR_POLL_TIMEOUT=600
PADDLEOCR_USE_DOC_ORIENTATION_CLASSIFY=False
PADDLEOCR_USE_DOC_UNWARPING=False
PADDLEOCR_USE_CHART_RECOGNITION=False
# OCR 提示词：引导模型聚焦服装电商相关文字。留空使用内置默认提示词。
PADDLEOCR_PROMPT=

# Optional human parsing model (SCHP-based clothing/body segmentation).
ILA_ENABLE_HUMAN_PARSER=0
ILA_HUMAN_PARSER_BACKEND=schp
ILA_HUMAN_PARSER_MODEL_PATH=

# Optional SAM2 mask refinement.
ILA_ENABLE_SAM2=0
SAM2_MODEL_CFG=
SAM2_CHECKPOINT=
