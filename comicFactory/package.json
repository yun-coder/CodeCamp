{
  "name": "comic-factory-monorepo",
  "version": "0.0.0",
  "private": true,
  "description": "AI color comic book studio built on an HTML/video generation pipeline",
  "license": "Apache-2.0",
  "engines": {
    "node": ">=20",
    "pnpm": ">=9"
  },
  "packageManager": "pnpm@9.15.0",
  "workspaces": [
    "packages/*",
    "templates/*"
  ],
  "scripts": {
    "build": "pnpm -r build",
    "typecheck": "pnpm -r typecheck",
    "test": "pnpm -r test",
    "smoke": "pnpm --filter @video-pipeline/cli smoke",
    "format": "biome format --write .",
    "lint": "biome lint ."
  },
  "devDependencies": {
    "@biomejs/biome": "^1.9.4",
    "@types/node": "^22.10.0",
    "typescript": "^5.7.2"
  }
}
