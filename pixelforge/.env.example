# pixelforge — example environment variables
# Copy to .env and fill in the keys you actually use. Every variable is
# optional; unconfigured providers simply report `available: false`.

# ── OpenAI-compatible VLM (used by vision + edit providers) ───────────
OPENAI_API_KEY=
OPENAI_BASE_URL=https://api.openai.com/v1
OPENAI_MODEL=gpt-4.1-mini
OPENAI_API_MODE=responses
OPENAI_REQUEST_TIMEOUT=120

# Vision planning model (usually a different / larger model than the agent text model)
OPENAI_VISION_PLAN_ENABLED=1
OPENAI_VISION_MODEL=gpt-4.1-mini

# Image edit / inpainting model
OPENAI_IMAGE_EDIT_ENABLED=1
IMAGE_EDIT_PROVIDER=openai_images
OPENAI_IMAGE_MODEL=gpt-image-2
OPENAI_IMAGE_QUALITY=medium

# Custom HTTP image-edit endpoint (use when OPENAI key lacks Images API)
# CUSTOM_IMAGE_EDIT_ENDPOINT=https://your-image-model-gateway.example.com/edit
# CUSTOM_IMAGE_EDIT_API_KEY=
# CUSTOM_IMAGE_EDIT_MODEL=

# ── PaddleOCR Cloud ────────────────────────────────────────────────────
ILA_OCR_PROVIDER=paddleocr_cloud
PADDLEOCR_ACCESS_TOKEN=
PADDLEOCR_BASE_URL=https://paddleocr.aistudio-app.com
PADDLEOCR_MODEL=PaddleOCR-VL-1.6
PADDLEOCR_REQUEST_TIMEOUT=60
PADDLEOCR_POLL_TIMEOUT=300

# ── Segment Anything (local, optional) ────────────────────────────────
SAM_CHECKPOINT=./checkpoints/sam_vit_b_01ec64.pth
SAM_MODEL_TYPE=vit_b          # vit_b | vit_l | vit_h
SAM_DEVICE=cpu                # cpu | cuda

# ── SAM2 (optional refinement) ────────────────────────────────────────
SAM2_CHECKPOINT=./checkpoints/sam2.1_hiera_small.pt
SAM2_MODEL_TYPE=sam2.1_hiera_small
SAM2_DEVICE=cpu

# ── Human parser (SCHP, optional) ────────────────────────────────────
SCHP_CHECKPOINT=./checkpoints/exp-schp-201908261155-lip.pth
SCHP_DEVICE=cpu

# ── Generative repair (optional, FLUX Kontext / LaMa / SD-Inpainting) ─
# REPAIR_PROVIDER=custom_http
# REPAIR_ENDPOINT=
# REPAIR_API_KEY=

# ── Storage / paths ───────────────────────────────────────────────────
PIXELFORGE_OUTPUT_DIR=./pixelforge_runs
PIXELFORGE_PORT=8700
PIXELFORGE_LOG_LEVEL=INFO
